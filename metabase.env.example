# --- Métadonnées Metabase (recommandé en prod : base MySQL dédiée "metabase") ---
# Sans Docker : exporte ces variables avant de lancer le JAR, ou mets-les dans un service systemd.
MB_DB_TYPE=mysql
MB_DB_DBNAME=metabase
MB_DB_HOST=127.0.0.1
MB_DB_PORT=3306
MB_DB_USER=metabase
MB_DB_PASS=change-me

# Démo rapide (sans DB MySQL pour Metabase) : ne pas définir MB_DB_* ; Metabase utilisera H2 embarqué
# (OK pour tester ; à éviter en production).

# Lancement sans Docker (exemple, après apt install openjdk-17-jre-headless) :
#   wget -O metabase.jar https://downloads.metabase.com/latest/metabase.jar
#   export $(grep -v '^#' metabase.env.example | xargs)   # si tu utilises MySQL pour Metabase
#   java -jar metabase.jar
# Puis ouvre http://<serveur>:3000

# Ensuite, dans l'UI Metabase, ajoute la base applicative:
# - Host: <mysql_host>
# - DB: rag_analytics
# - User: rag_user (ou un user read-only)
# - Password: <...>
